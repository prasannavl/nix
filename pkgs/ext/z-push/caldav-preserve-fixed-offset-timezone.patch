+    private static function tzidFromFixedOffset($phpoffset) {
+        if ($phpoffset % 3600 !== 0) {
+            return null;
+        }
+
+        $hours = (int) ($phpoffset / 3600);
+        if ($hours < -12 || $hours > 14) {
+            return null;
+        }
+
+        if ($hours == 0) {
+            return "Etc/GMT";
+        }
+
+        $sign = $hours > 0 ? "-" : "+";
+        return sprintf("Etc/GMT%s%d", $sign, abs($hours));
+    }
