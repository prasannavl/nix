diff --git a/src/lib/utils/timezoneutil.php b/src/lib/utils/timezoneutil.php
index 521b99f3..3f2153d4 100644
--- a/src/lib/utils/timezoneutil.php
+++ b/src/lib/utils/timezoneutil.php
@@ -1380,6 +1380,32 @@ class TimezoneUtil {
         return $dtz;
     }

+    /**
+     * Returns a PHP-supported IANA timezone from a Windows timezone name.
+     *
+     * @param string $winTz Timezone name in Windows, e.g. "Singapore Standard Time"
+     *
+     * @access public
+     * @return string|false
+     */
+    public static function GetPhpTimezoneFromWinTZName($winTz = false) {
+        if ($winTz === false) {
+            return false;
+        }
+
+        $winTz = trim(str_replace("\0", "", (string)$winTz));
+        if ($winTz === "" || !isset(self::$phptimezones[$winTz])) {
+            return false;
+        }
+
+        foreach (self::$phptimezones[$winTz] as $phpTz) {
+            if (in_array($phpTz, DateTimeZone::listIdentifiers(), true)) {
+                return $phpTz;
+            }
+        }
+        return false;
+    }
+
