+/**
+ * Detect if one message has an iTIP scheduling VCALENDAR part.
+ *
+ * This is intentionally narrower than has_calendar_object(): a normal e-mail
+ * may attach an .ics file, while ActiveSync calendar clients often emit
+ * REQUEST/REPLY/CANCEL iMIP messages in parallel with their CalDAV write.
+ *
+ * @param Mail_mimeDecode $message
+ * @return boolean
+ */
+function has_scheduling_calendar_object($message) {
+    if (is_calendar($message)) {
+        $method = $message->ctype_parameters['method'] ?? null;
+        $body = $message->body ?? "";
+        return ($method !== null && preg_match('/^(REQUEST|REPLY|CANCEL)$/i', $method)) ||
+            preg_match('/^\s*METHOD\s*:\s*(REQUEST|REPLY|CANCEL)\s*$/mi', $body);
+    }
+
+    if(isset($message->parts)) {
+        for ($i = 0; $i < count($message->parts); $i++) {
+            if (has_scheduling_calendar_object($message->parts[$i])) {
+                return true;
+            }
+        }
+    }
+
+    return false;
+}
