@@ -210,0 +200,79 @@ impl<T: SessionStream> SessionData<T> {
+
+fn quota_response(root_name: String, disk_quota: u64, used_quota: u64) -> Response {
+    Response {
+        quota_root_items: vec![],
+        quota_items: vec![quota_item(root_name, disk_quota, used_quota)],
+    }
+}
+
+fn quota_root_response(
+    mailbox_name: String,
+    account_id: u32,
+    disk_quota: u64,
+    used_quota: u64,
+) -> Response {
+    let mut quota_root_items = vec![mailbox_name];
+    let mut quota_items = Vec::with_capacity(1);
+
+    if disk_quota > 0 {
+        let quota_item = quota_item(format!("#{account_id}"), disk_quota, used_quota);
+        quota_root_items.push(quota_item.name.clone());
+        quota_items.push(quota_item);
+    }
+
+    Response {
+        quota_root_items,
+        quota_items,
+    }
+}
+
+fn quota_item(root_name: String, disk_quota: u64, used_quota: u64) -> QuotaItem {
+    QuotaItem {
+        name: root_name,
+        resources: vec![QuotaResource {
+            resource: QuotaResourceName::Storage,
+            total: disk_quota,
+            used: used_quota,
+        }],
+    }
+}
+
+#[cfg(test)]
+mod tests {
+    use imap_proto::protocol::ImapResponse;
+
+    use super::{quota_response, quota_root_response};
+
+    #[test]
+    fn get_quota_with_limit_emits_storage_resource() {
+        let response = quota_response("#7".into(), 4096, 2048);
+
+        assert_eq!(
+            String::from_utf8(response.serialize()).unwrap(),
+            "* QUOTA \"#7\" (STORAGE 2 4)\r\n"
+        );
+    }
+
+    #[test]
+    fn get_quota_root_without_limit_does_not_advertise_quota_root() {
+        let response = quota_root_response("Deleted Items".into(), 7, 0, 2048);
+
+        assert_eq!(
+            String::from_utf8(response.serialize()).unwrap(),
+            "* QUOTAROOT \"Deleted Items\"\r\n"
+        );
+    }
+
+    #[test]
+    fn get_quota_root_with_limit_emits_quota_root_and_resource() {
+        let response = quota_root_response("Deleted Items".into(), 7, 4096, 2048);
+
+        assert_eq!(
+            String::from_utf8(response.serialize()).unwrap(),
+            concat!(
+                "* QUOTAROOT \"Deleted Items\" \"#7\"\r\n",
+                "* QUOTA \"#7\" (STORAGE 2 4)\r\n"
+            )
+        );
+    }
+}
