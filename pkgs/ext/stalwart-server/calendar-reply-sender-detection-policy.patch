+pub fn itip_reply_sender(
+    smtp_sender: &str,
+    snapshots: &ItipSnapshots<'_>,
+    itip_snapshots: &ItipSnapshots<'_>,
+) -> Option<String> {
+    let mut sender = None;
+
+    for (instance_id, itip_snapshot) in &itip_snapshots.components {
+        let snapshot = snapshots.components.get(instance_id)?;
+
+        for updated_attendee in &itip_snapshot.attendees {
+            let Some(attendee) = snapshot.attendee_by_email(&updated_attendee.email.email) else {
+                continue;
+            };
+
+            let changed = attendee.part_stat != updated_attendee.part_stat
+                || attendee.rsvp != updated_attendee.rsvp
+                || attendee.delegated_to != updated_attendee.delegated_to
+                || !itip_snapshot.request_status.is_empty();
+
+            if changed {
+                if !sender_matches_attendee(smtp_sender, attendee)
+                    && !sender_matches_attendee(smtp_sender, updated_attendee)
+                {
+                    return None;
+                }
+
+                if sender
+                    .as_ref()
+                    .is_some_and(|sender| sender != &updated_attendee.email.email)
+                {
+                    return None;
+                }
+
+                sender = Some(updated_attendee.email.email.clone());
+            }
+        }
+    }
+
+    sender
+}
+
+fn sender_matches_attendee(sender: &str, attendee: &Attendee<'_>) -> bool {
+    attendee.email.email.eq_ignore_ascii_case(sender)
+        || attendee
+            .sent_by
+            .as_ref()
+            .is_some_and(|sent_by| sent_by.email.eq_ignore_ascii_case(sender))
+}
