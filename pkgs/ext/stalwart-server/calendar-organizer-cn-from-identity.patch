+async fn hydrate_organizer_cn_from_identity(
+    server: &Server,
+    account_id: u32,
+    ical: &mut ICalendar,
+) -> trc::Result<()> {
+    let Some(identities) = server.participant_identity_get_or_create(account_id).await? else {
+        return Ok(());
+    };
+    let identities = identities
+        .deserialize::<ParticipantIdentities>()
+        .caused_by(trc::location!())?;
+
+    for component in &mut ical.components {
+        if !component.component_type.is_scheduling_object() {
+            continue;
+        }
+
+        for entry in &mut component.entries {
+            if entry.name != ICalendarProperty::Organizer
+                || has_non_empty_cn(entry)
+                || entry.values.is_empty()
+            {
+                continue;
+            }
+
+            let Some(email) = calendar_entry_email(entry) else {
+                continue;
+            };
+            let Some(name) = organizer_identity_name(&identities, &email) else {
+                continue;
+            };
+
+            entry
+                .params
+                .retain(|param| param.name != ICalendarParameterName::Cn);
+            entry.params.push(ICalendarParameter {
+                name: ICalendarParameterName::Cn,
+                value: ICalendarParameterValue::Text(name),
+            });
+        }
+    }
+
+    Ok(())
+}
+
+fn has_non_empty_cn(entry: &ICalendarEntry) -> bool {
+    entry.params.iter().any(|param| {
+        matches!(
+            (&param.name, &param.value),
+            (ICalendarParameterName::Cn, ICalendarParameterValue::Text(name))
+                if !name.trim().is_empty()
+        )
+    })
+}
+
+fn calendar_entry_email(entry: &ICalendarEntry) -> Option<String> {
+    let value = entry.values.first()?;
+    let value = value.as_text().or_else(|| match value {
+        ICalendarValue::Uri(Uri::Location(uri)) => Some(uri.as_str()),
+        _ => None,
+    })?;
+    let value = value.trim();
+    let value = value
+        .get(..7)
+        .filter(|prefix| prefix.eq_ignore_ascii_case("mailto:"))
+        .map(|_| &value[7..])
+        .unwrap_or(value)
+        .trim();
+    value.contains('@').then(|| value.to_lowercase())
+}
+
+fn organizer_identity_name(identities: &ParticipantIdentities, email: &str) -> Option<String> {
+    identities
+        .identities
+        .iter()
+        .find(|identity| calendar_address_email(&identity.calendar_address).as_deref() == Some(email))
+        .map(|identity| identity.name.as_deref().unwrap_or(&identities.default_name))
+        .map(str::trim)
+        .filter(|name| !name.is_empty())
+        .map(ToString::to_string)
+}
+
+fn calendar_address_email(value: &str) -> Option<String> {
+    let value = value.trim();
+    let value = value
+        .get(..7)
+        .filter(|prefix| prefix.eq_ignore_ascii_case("mailto:"))
+        .map(|_| &value[7..])
+        .unwrap_or(value)
+        .trim();
+    value.contains('@').then(|| value.to_lowercase())
+}
