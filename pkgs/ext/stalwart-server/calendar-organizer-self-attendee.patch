+pub fn itip_remove_organizer_attendees(ical: &mut ICalendar) {
+    for component in &mut ical.components {
+        if !component.component_type.is_scheduling_object() {
+            continue;
+        }
+
+        let organizer_email = component
+            .entries
+            .iter()
+            .find(|entry| entry.name == ICalendarProperty::Organizer)
+            .and_then(entry_email);
+
+        component.entries.retain(|entry| {
+            entry.name != ICalendarProperty::Attendee
+                || entry_email(entry) != organizer_email
+        });
+    }
+}
