+pub(crate) fn entry_email(entry: &ICalendarEntry) -> Option<String> {
+    let value = entry.values.first()?;
+    let email = value
+        .as_text()
+        .or_else(|| match value {
+            ICalendarValue::Uri(Uri::Location(uri)) => Some(uri.as_str()),
+            _ => None,
+        })?
+        .trim();
+    let email = email
+        .get(..7)
+        .filter(|prefix| prefix.eq_ignore_ascii_case("mailto:"))
+        .map(|_| &email[7..])
+        .unwrap_or(email)
+        .trim();
+    email.contains('@').then(|| email.to_lowercase())
+}
