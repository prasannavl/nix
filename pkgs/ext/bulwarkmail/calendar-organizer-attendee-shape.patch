+function normalizeCalendarAddress(value?: string | null): string {
+  return (value || '').replace(/^mailto:/i, '').toLowerCase();
+}
+
+function isOrganizerParticipant(event: CalendarEvent, p: CalendarParticipant): boolean {
+  if (p.roles?.owner) return true;
+  if (!event.organizerCalendarAddress) return false;
+  const organizer = normalizeCalendarAddress(event.organizerCalendarAddress);
+  return organizer !== '' && (
+    normalizeCalendarAddress(p.email) === organizer ||
+    normalizeCalendarAddress(p.calendarAddress) === organizer ||
+    normalizeCalendarAddress(p.sendTo?.imip) === organizer
+  );
+}
